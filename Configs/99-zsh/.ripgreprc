# Ripgrep (rg) configuration file
# Settings for the fast, recursive grep replacement
#
# NOTE: Theme-agnostic color configuration!
# Colors use ANSI palette mapping (0-15) not hardcoded hex values.
# This ensures rg output adapts to the active kitty theme.
# See ~/.theme-colors for central color configuration.

# ==============================================================================
# Search Options
# ==============================================================================
# Smart case: search is case-insensitive unless pattern contains uppercase
--smart-case

# Include hidden files and directories in search
--hidden

# Show file path above matches (improves readability)
--heading

# Trim whitespace from matches
--trim

# Disable line numbers by default (can override with -n flag)
--no-line-number

# ==============================================================================
# Color Configuration (Theme-Agnostic)
# ==============================================================================
# Use terminal color palette (colors 0-15) instead of hardcoded hex values
# Red text for matching content
--colors=match:fg:red

# Green text for line numbers (if enabled with -n)
--colors=line:fg:green

# Cyan text for file paths
--colors=path:fg:cyan

# White text for column numbers
--colors=column:fg:white

# ==============================================================================
# Advanced Search
# ==============================================================================
# Stay on one file system (don't cross file system boundaries)
--one-file-system

# Print preview for lines exceeding max column limit
--max-columns-preview

# ==============================================================================
# Additional Options (Disabled)
# ==============================================================================
# Uncomment to enable:

# Search in compressed files
#--search-zip

# Automatically select the best regex engine
#--engine auto

# Follow symlinks during search
#--follow

# Ignore .git directory
#--glob !.git

# Ignore *.bak files
#--glob !.bak

# Ignore backup directories
#--glob !*/backup/*

# Make glob patterns case-insensitive
#--glob-case-insensitive

# Use .gitignore file
#--ignore-file
#.gitignore

# Search all types by default
#--type all
