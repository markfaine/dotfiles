# Ripgrep (rg) configuration file
# Settings for the fast, recursive grep replacement

# ==============================================================================
# Search Options
# ==============================================================================
# Smart case: search is case-insensitive unless pattern contains uppercase
--smart-case

# Include hidden files and directories in search
--hidden

# Show file path above matches (improves readability)
--heading

# Trim whitespace from matches
--trim

# Disable line numbers by default (can override with -n flag)
--no-line-number

# ==============================================================================
# Advanced Search
# ==============================================================================
# Stay on one file system (don't cross file system boundaries)
--one-file-system

# Print preview for lines exceeding max column limit
--max-columns-preview

# ==============================================================================
# Additional Options (Disabled)
# ==============================================================================
# Uncomment to enable:

# Search in compressed files
#--search-zip

# Automatically select the best regex engine
#--engine auto

# Follow symlinks during search
#--follow

# Ignore .git directory
#--glob !.git

# Ignore *.bak files
#--glob !.bak

# Ignore backup directories
#--glob !*/backup/*

# Make glob patterns case-insensitive
#--glob-case-insensitive

# Use .gitignore file
#--ignore-file
#.gitignore

# Search all types by default
#--type all
