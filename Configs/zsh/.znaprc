
# shellcheck shell=zsh
# Znap plugin manager configuration
# Manages plugin installation, loading, PATH/FPATH updates, and per-plugin config

# ==============================================================================
# Znap Bootstrap
# ==============================================================================
# Download znap plugin manager if not already present
function _download_znap(){
  if [[ ! -d "$ZNAP_HOME" ]]; then
      zdebug ".znaprc: $ZNAP_HOME does not exist cloning the repo"
      git clone --depth 1 -- "https://github.com/marlonrichert/zsh-snap.git" "$ZNAP_HOME"
  fi
}

# ==============================================================================
# Plugin Loading
# ==============================================================================
# Load plugins from .zplugins file
# Handles:
#   - Per-plugin configuration files (~/.config/zplugin.d/plugin-name.zsh)
#   - Cloning repositories
#   - Adding plugin paths to PATH
#   - Adding plugin completion paths to FPATH
#   - Sourcing plugins
#
# File format: ~/.zplugins
# CSV format: github-org/repo,path-addition,fpath-addition
# - Empty lines and comments (starting with #) are ignored
function _load_plugins(){
    local plugins_file repo repo_array plugin include_path completion_path
    plugins_file="${1:-$HOME/.zplugins}"
    if [[ ! -f "$plugins_file" ]]; then
        printf "Plugins file '%s' was not found!\n" "$plugins_file"
        return
    fi
    while IFS=',' read -r repo include_path completion_path; do
        line="$repo$include_path$completion_path"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ '^#[[:space:]]*' ]] && continue
        zdebug ".znaprc: Loading plugin '$repo'"
        repo_array=(${(s:/:)repo})
        plugin="$repo_array[2]"
        # Source per-plugin configuration if it exists
        if [[ -f "$HOME/.config/zplugin.d/$plugin.zsh" ]]; then
            zdebug ".znaprc: Sourcing $HOME/.config/zplugin.d/$plugin.zsh"
            source "$HOME/.config/zplugin.d/$plugin.zsh"
        fi
        znap clone "$repo"
        # Add plugin path entries to PATH
        if [[ "${include_path:-}" != "" ]]; then
            zdebug ".znaprc: Adding [$repo]/$include_path to the PATH"
            path=( ~[$repo]/$include_path $path )
        fi
        # Add plugin completion path entries to FPATH
        if [[ "${completion_path:-}" != "" ]]; then
            zdebug ".znaprc: Adding [$repo]/$completion_path to the FPATH"
            fpath=( ~[$repo]/$completion_path $fpath )
        fi
        zdebug ".znaprc: Sourcing $repo"
        if ! znap source "$repo" &>/dev/null; then
            zdebug ".znaprc: Failed to source '$repo'"
        fi
    done < "$plugins_file"
}

# ==============================================================================
# Znap Initialization
# ==============================================================================
# Initialize the znap plugin manager
function _load_znap(){
  if [[ -f "$ZNAP_HOME/znap.zsh" ]]; then
    zdebug ".znaprc: Sourcing $ZNAP_HOME/znap.zsh"
    source "$ZNAP_HOME/znap.zsh"
  else
    zdebug ".znaprc: Failed to source $ZNAP_HOME/znap.zsh!"
    printf "See log file at '%s'\n" "$ZLOG_FILE"
    return
  fi
}

# ==============================================================================
# Znap Setup & Plugin Loading
# ==============================================================================
ZNAP_HOME="$HOME/.config/repos/znap"
zdebug ".znaprc: ZNAP_HOME: $ZNAP_HOME"
zstyle ':znap:*' "$ZNAP_HOME"
export ZNAP_HOME

_download_znap || return
_load_znap || return
_load_plugins || return
