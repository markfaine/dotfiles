# User Command Aliases File
# Collection of shell aliases and functions for common tasks

# ==============================================================================
# Editor Configuration
# ==============================================================================
export EDITOR=nvim
alias vim='nvim'
alias vi='nvim'

# Stock vim/vi access (for when you really need the original)
alias svim="/usr/bin/vi"

# ==============================================================================
# Directory Navigation
# ==============================================================================
# typo protection
alias cd..='cd ..'

# Shorter previous dir
alias -- -='cd -'

# ==============================================================================
# Screen/Terminal
# ==============================================================================
# Clear screen
alias c='clear'
alias claer='clear'
alias clar='clear'

# ==============================================================================
# Disk & File Management
# ==============================================================================
alias df='df -kTh'
alias du='du -kh'

# List files
# If eza
if (( $+commands[eza] )); then
  # General listing
  alias ls='eza --icons --group-directories-first'
  alias l='eza -lbF --git --icons'                     # Detailed list
  alias ll='eza -lbGF --header --git --icons'          # Long list with headers
  alias llm='eza -lbGd --git --sort=modified --icons'  # Sort by date

  # "All" views (including hidden files)
  alias la='eza -lbhHigUmuSa --time-style=long-iso --git --color-scale --icons'
  alias lx='eza -lbhHigUmuSa@ --time-style=long-iso --git --color-scale --icons'

  # Specialty views
  alias lS='eza -1 --icons'                            # Single column
  alias lt='eza --tree --level=2 --icons'              # 2-level deep tree
  alias tree='eza --tree --icons'                      # Full tree
  # typo protection
  alias ls-la='la'
else
  # basic ls aliases
  alias ls='ls --color'
  alias ll='ls -la'
  # typo protection
  alias kk='ll'
  alias ls-la='ls -la'
fi

# Move with safety confirmation
alias mv='mv -i'

# Pager alternatives and typo protection
alias moer='more'
alias moew='more'
alias more='less'
alias tial='tail'

# ==============================================================================
# Process Management
# ==============================================================================
# Show all processes with full details
alias ps='ps -ef'

# Jobs management
alias j='jobs -l'

# Better process monitoring
if (( $+commands[htop] )); then
  alias top=htop
fi

# ==============================================================================
# History & Command Help
# ==============================================================================
alias h='history'

# which → command -v (shows where command comes from)
alias which='command -v'

# ==============================================================================
# Trash/Recycle Bin
# ==============================================================================
alias trm='trash-put'
alias trl='trash-list'

# ==============================================================================
# File Search & Grep
# ==============================================================================
alias rgrep='rg -IN -uuu'
alias ff='fd'
alias f='fd -HI'

# ==============================================================================
# System & Service Management
# ==============================================================================
# Journalctl integration
alias journalctl='journalctl'
if [[ "${WT_SESSION:-}" != "" ]]; then
    alias journalctl='journalctl --no-pager -xeu'
fi

# Journalctl convenience functions
function jcu(){
    local unit
    unit="$1"
    if [[ -z "$unit" ]]; then
      printf "Need a service name\n"
    else
        journalctl -xfu "$unit"
    fi
}
alias jc='journalctl -xn'
alias jcf='journalctl -xf'

# ==============================================================================
# Text Processing
# ==============================================================================
# Use gawk if available (better than mawk)
if command -v gawk >/dev/null 2>&1; then
    alias awk='gawk'
fi

# ==============================================================================
# Version Control - Git
# ==============================================================================
# Performance: disable pager for built-in git output
alias git='git --no-pager'
alias gits='git status'
alias gitcfg='git config --list --show-origin --show-scope'
alias gdh='git dh'

# ==============================================================================
# Multiplexer - Tmux
# ==============================================================================
# Always use 256 colors
alias tmux='tmux -2'

# ==============================================================================
# Container Management - Docker
# ==============================================================================
alias dockerps='docker ps -a --format="table {{.ID}}\t{{.Names}}\t{{.Image}}\t{{.Command}}\t{{.Status}}"'

# ==============================================================================
# Build & Format Tools
# ==============================================================================
alias prettier='npx prettier'

# ==============================================================================
# Advanced File Search & Utils
# ==============================================================================
# df → duf (better disk usage visualization)
alias df='duf'

# Display PATH entries one per line for readability
alias mypath='echo -e ${PATH//:/\\n}'

# ==============================================================================
# Shell Management
# ==============================================================================
# Reload shell configuration
alias zbrc='exec zsh'
