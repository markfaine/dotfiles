#  eval "$(ssh-agent -s; SSH_ASKPASS=$SSH_ASKPASS)"
#  ssh-add -K || true
# }
# ssh_load

setopt clobber
ssh_load() {
  local SSH_ENV="$HOME/.ssh-agent"

  # Try to reuse saved agent env
  if [ -f "$SSH_ENV" ]; then
    # shellcheck disable=SC1090
    . "$SSH_ENV"
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ] && ssh-add -l >|/dev/null 2>&1; then
      return 0
    fi
  fi

  # Start a new agent
  eval "$(ssh-agent -s)" >/dev/null

  # Save agent env (use printf to avoid heredoc indentation issues)
  printf '%s\n' "export SSH_AUTH_SOCK=$SSH_AUTH_SOCK" "export SSH_AGENT_PID=$SSH_AGENT_PID" > "$SSH_ENV"
  chmod 600 "$SSH_ENV"

  # If there are no identities, try -K then fallback to default ssh-add
  if ! ssh-add -l >/dev/null 2>&1; then
    # Disable SSH_ASKPASS for these calls so we get a terminal prompt (avoid GUI dialogs)
    if SSH_ASKPASS= ssh-add -K >/dev/null 2>&1; then
      return 0
    else
      SSH_ASKPASS= ssh-add >/dev/null 2>&1 || true
    fi
  fi
}
ssh_load
