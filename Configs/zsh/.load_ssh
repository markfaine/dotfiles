# shellcheck shell=zsh
# SSH Agent management and initialization
# Handles persistent SSH agent session across shell invocations

# ==============================================================================
# SSH Agent Configuration
# ==============================================================================
# Use clobber to safely redirect output
setopt clobber

# SSH agent environment file location (persisted between sessions)
SSH_ENV="$HOME/.ssh-agent"

# ==============================================================================
# SSH Agent Management Function
# ==============================================================================
# Initialize or reuse SSH agent session
# - Attempts to reuse existing agent environment
# - Falls back to creating new agent if needed
# - Loads SSH keys with optional keychain support
ssh_load() {
  # Ensure function never causes shell to exit
  setopt local_options no_unset 2>/dev/null || true

  # Debug mode: set SSH_AGENT_DEBUG=1 to see diagnostic output
  local debug=${SSH_AGENT_DEBUG:-0}

  # Try to reuse saved agent env from previous session
  if [[ -f "$SSH_ENV" ]]; then
    # shellcheck disable=SC1090
    source "$SSH_ENV" 2>/dev/null || true
    [[ $debug -eq 1 ]] && echo "[ssh-agent] Loaded saved env: PID=$SSH_AGENT_PID, SOCK=$SSH_AUTH_SOCK" >&2

    # Verify agent process is still actually running (cross-session persistence)
    # This catches cases where socket/pid are stale after closing/reopening terminal
    if [[ -n "${SSH_AGENT_PID:-}" ]] && kill -0 "$SSH_AGENT_PID" 2>/dev/null; then
      [[ $debug -eq 1 ]] && echo "[ssh-agent] Process $SSH_AGENT_PID is running" >&2

      # Verify socket is accessible
      if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "$SSH_AUTH_SOCK" ]]; then
        [[ $debug -eq 1 ]] && echo "[ssh-agent] Socket $SSH_AUTH_SOCK exists" >&2

        local ssh_add_result
        ssh-add -l &>/dev/null
        ssh_add_result=$?
        [[ $debug -eq 1 ]] && echo "[ssh-agent] ssh-add -l returned: $ssh_add_result" >&2

        # Accept 0 (has identities) or 1 (no identities but agent running)
        if [[ $ssh_add_result -eq 0 ]] || [[ $ssh_add_result -eq 1 ]]; then
          [[ $debug -eq 1 ]] && echo "[ssh-agent] ✓ Reusing existing agent" >&2
          return 0
        fi
      else
        [[ $debug -eq 1 ]] && echo "[ssh-agent] Socket check failed" >&2
      fi
    else
      [[ $debug -eq 1 ]] && echo "[ssh-agent] Process check failed (PID may be stale)" >&2
    fi

    # Clean up stale env file if we couldn't reuse the agent
    [[ $debug -eq 1 ]] && echo "[ssh-agent] Removing stale env file" >&2
    rm -f "$SSH_ENV" 2>/dev/null
  fi

  # Start a new SSH agent session only in appropriate contexts
  # Skip in tmux or non-interactive environments
  if [[ -n "${TMUX:-}" ]] || [[ ! -o interactive ]]; then
    [[ $debug -eq 1 ]] && echo "[ssh-agent] Skipping agent creation (tmux or non-interactive)" >&2
    return 0
  fi

  [[ $debug -eq 1 ]] && echo "[ssh-agent] Starting new ssh-agent" >&2

  # Start SSH agent
  local agent_output
  agent_output=$(ssh-agent -s 2>/dev/null) || return 0
  eval "$agent_output" >/dev/null 2>&1 || return 0

  [[ $debug -eq 1 ]] && echo "[ssh-agent] ✓ New agent started: PID=$SSH_AGENT_PID" >&2

  # Persist agent environment for future sessions
  if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -n "${SSH_AGENT_PID:-}" ]]; then
    {
      printf '%s\n' "export SSH_AUTH_SOCK=$SSH_AUTH_SOCK" "export SSH_AGENT_PID=$SSH_AGENT_PID"
    } > "$SSH_ENV" 2>/dev/null && chmod 600 "$SSH_ENV" 2>/dev/null
    [[ $debug -eq 1 ]] && echo "[ssh-agent] Saved agent info to $SSH_ENV" >&2
  fi

  # Don't attempt to load keys in non-interactive contexts
  # This prevents prompts that could hang or cause issues
  return 0
}

# ==============================================================================
# Initialize SSH Agent
# ==============================================================================
# Call ssh_load but ensure it doesn't cause failures
ssh_load 2>/dev/null || true
