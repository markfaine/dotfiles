# shellcheck shell=zsh
# Znap plugin manifest
# This file defines all zsh plugins to be loaded via znap
#
# The _load_plugins function in ~/.znaprc processes each line:
# 1. Clones the plugin repository (if not already present)
# 2. Adds second comma-separated field to PATH (if provided)
# 3. Adds third comma-separated field to FPATH for completions (if provided)
# 4. Sources the plugin
#
# Per-plugin configuration can be placed in ~/.config/zplugin.d/plugin-name.zsh
#
# Format:
# github-repo-path,path-addition,fpath-addition
#
# Notes:
# - Order mostly matters for completions (should go last)
# - Empty lines and lines starting with # are ignored
# - Both path arguments are optional (use empty field)

# ==============================================================================
# Core Environment & Utilities
# ==============================================================================
zimfw/environment
zimfw/utility,functions
zimfw/prompt-pwd

# ==============================================================================
# Terminal & Display
# ==============================================================================
chrissicool/zsh-256color
marlonrichert/zcolors
zimfw/input
zimfw/termtitle
zimfw/run-help

# ==============================================================================
# Syntax & History
# ==============================================================================
zsh-users/zsh-autosuggestions
zsh-users/zsh-history-substring-search
zsh-users/zsh-syntax-highlighting

# ==============================================================================
# CLI Tools & Integrations
# ==============================================================================
MohamedElashri/eza-zsh
zimfw/fzf
joke/zim-github-cli
# lukechilds/zsh-nvm
# joke/zim-mise
joke/zim-yq
kiesman99/zim-zoxide
thetic/extract
lukechilds/zsh-nvm

# ==============================================================================
# Completions (should be loaded last)
# ==============================================================================
zsh-users/zsh-completions,,src
Freed-Wu/zsh-command-not-found
