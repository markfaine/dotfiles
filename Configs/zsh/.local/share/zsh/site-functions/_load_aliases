# ==============================================================================
# File Sourcing: Aliases
# ==============================================================================
# Load command aliases
  ZALIASES="${ZDOTDIR:-$HOME}/.aliases"
  if [[ -e "$ZALIASES" ]]; then
    #shellcheck source=/dev/null
    . "$ZALIASES"
    zdebug "_load_aliases: Sourcing $ZALIASES"
  else
    zdebug "_load_aliases: Failed to source $ZALIASES"
  fi
