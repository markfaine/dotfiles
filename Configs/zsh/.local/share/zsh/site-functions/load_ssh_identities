CONFIG_KEY=$(grep -m1 "IdentityFile" "$HOME/.ssh/config" 2>/dev/null | awk '{print $2}' | sed "s|^~|$HOME|")
DEFAULT_KEY="$HOME/.ssh/id_rsa"

# Only run if ssh-add is available
(( $+commands[ssh-add] )) || return 0

# Check if agent is accessible
ssh-add -l &>/dev/null
local agent_status=$?
if [[ $agent_status -eq 2 ]]; then
    zdebug "load_ssh_identities: No SSH agent available"
    return 0
fi

# Case 1: Check for YubiKey
local has_yubikey=0
if (( $+commands[lsusb] )) && lsusb 2>/dev/null | grep -q "1050"; then
    has_yubikey=1
elif (( $+commands[system_profiler] )) && system_profiler SPUSBDataType 2>/dev/null | grep -q "Yubico"; then
    has_yubikey=1
fi

if [[ $has_yubikey -eq 1 ]]; then
    # Check if a YubiKey (sk-) key is already in the agent
    if ! ssh-add -l 2>/dev/null | grep -q "sk-"; then
        zdebug "load_ssh_identities: Adding YubiKey keys"
        # Only attempt to add if it's the first time in this session or agent is empty
        # This will trigger the PIN prompt ONCE.
        SSH_ASKPASS=$SSH_ASKPASS SSH_ASKPASS_REQUIRE=$SSH_ASKPASS_REQUIRE ssh-add -K 2>/dev/null
    fi
    return 0
fi

# Case 2: Load file-based keys
local target_key="${CONFIG_KEY:-$DEFAULT_KEY}"
if [[ -f "$target_key" ]]; then
    local fingerprint=$(ssh-keygen -lf "$target_key" 2>/dev/null | awk '{print $2}')
    if [[ -n "$fingerprint" ]] && ! ssh-add -l 2>/dev/null | grep -q "$fingerprint"; then
        ssh-add "$target_key" 2>/dev/null
    fi
fi
