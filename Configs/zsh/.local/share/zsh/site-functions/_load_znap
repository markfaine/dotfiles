# ==============================================================================
# Znap Initialization
# ==============================================================================
# Initialize the znap plugin manager
  if [[ -f "$ZNAP_HOME/znap.zsh" ]]; then
    zdebug ".znaprc: Sourcing $ZNAP_HOME/znap.zsh"
    source "$ZNAP_HOME/znap.zsh"
  else
    zdebug ".znaprc: Failed to source $ZNAP_HOME/znap.zsh!"
    printf "See log file at '%s'\n" "$ZLOG_FILE"
    return
  fi
