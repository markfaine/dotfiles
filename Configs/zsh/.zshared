# A collection of shared functions
# shellcheck shell=zsh

# Send to trash-bin, if trash-put command exists ,else just rm
# TODO: Make a $HOME/.Trash that is mounted from /mnt/d
# Setup Trash directory
export TRASH_DIR_LOCAL="$HOME/.Trash"
TRASH_MOUNT="/mnt/d"
export TRASH_DIR="$TRASH_MOUNT/.Trash"
function trm() {
  if command -v trash-put &>/dev/null; then
    recycle_bin="$TRASH_DIR_LOCAL"
    if _is_mounted "$TRASH_MOUNT"; then
      zdebug ".zshared: $TRASH_MOUNT is mounted"
      recycle_bin="$TRASH_DIR"
    fi
    trash-put --trash-dir "$recycle_bin" "$@"
  else
    /usr/bin/rm "$@"
  fi
}

# Customized docker ps
docker() {
  case $1 in
    ps)
      shift
      command dops "$@"
      ;;
    *)
      command docker "$@";;
  esac
}

# Login to container
shell(){
  local ctnr cmd
  ctnr="$1"
  if [[ -z "$ctnr" ]]; then
    echo "Usage: shell <container> [command]" >&2
    return 1
  fi
  shift
  cmd="${1:-/bin/sh}"

  # Find container ID dynamically by looking for a service name that ends with the container name,
  # or matches it exactly.
  local ctnr_ids
  ctnr_ids=$(/usr/bin/docker ps --format '{{.ID}} {{.Label "com.docker.swarm.service.name"}}' | \
    awk -v ctnr="$ctnr" '$2 == ctnr || $2 ~ "_"(ctnr)"$" {print $1}')

  if [[ -z "$ctnr_ids" ]]; then
    echo "No container found for '$ctnr'" >&2
    return 1
  fi

  if [[ $(echo "$ctnr_ids" | wc -l) -gt 1 ]]; then
    echo "Multiple containers match '$ctnr'. Please be more specific." >&2
    echo "Matching services:" >&2
    /usr/bin/docker ps --format '{{.Label "com.docker.swarm.service.name"}}' | \
        awk -v ctnr="$ctnr" '$0 == ctnr || $0 ~ "_"(ctnr)"$"'
    return 1
  fi

  docker exec -it "$ctnr_ids" "$cmd"
}

export _zshared_loaded=1
